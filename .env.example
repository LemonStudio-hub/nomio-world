# ============================================================
# Nomio.World 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ============================================================

# Cloudflare 认证
CLOUDFLARE_API_TOKEN=your_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# D1 数据库（deploy.sh 自动填入 wrangler.toml）
DATABASE_ID=auto_generated_by_deploy_script

# API Worker 密钥（deploy.sh 自动生成）
JWT_SECRET=auto_generated_by_deploy_script

# CORS 允许的源
ALLOWED_ORIGINS=https://nomio.world,https://www.nomio.world
